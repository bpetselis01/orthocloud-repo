# Step 1: Application environment
# Controls FastAPI behaviour — use "development" locally, "production" in staging/prod
APP_ENV=development

# Step 2: Backend server settings
# HOST and PORT are used by Uvicorn inside the container
# Change PORT here and in docker-compose.yml if 8000 conflicts locally
HOST=0.0.0.0
PORT=8000

# Step 3: Pipeline temp directory
# FastAPI writes uploaded ZIP files here before extraction
# Must be writable by the backend container user
TEMP_DIR=/tmp/orthocloud

# Step 4: GPU/segmentation settings (Phase 2 — leave blank for now)
# MONAI Deploy and TotalSegmentator configuration goes here in Step 3
# TOTALSEG_WEIGHTS_PATH=
# CUDA_VISIBLE_DEVICES=
