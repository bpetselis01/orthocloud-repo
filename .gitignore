# Step 1: Python virtual environments
# These are locally installed package trees — never commit them
.venv/
venv/
env/
ENV/

# Step 2: Python bytecode and build artefacts
# Generated automatically by the interpreter — not source code
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Step 3: Test and lint tool caches
# Recreated on every run — no value in version control
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Step 4: Environment files
# .env contains real secrets — never commit it
# .env.example is the committed template with no real values
.env

# Step 5: Temporary pipeline output
# DICOM files, NIfTI masks, and ZIP uploads are patient data artefacts
# They must never be committed — even synthetic ones could contain PHI-shaped data
tmp/
temp/
*.nii
*.nii.gz
*.dcm
*.zip

# Step 6: Editor and OS noise
# Generated by IDEs and operating systems — not part of the project
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
